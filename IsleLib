			local startPos = nil

			local function updateInput(input)
				local delta = input.Position - dragStart
				local position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
					startPos.Y.Scale, startPos.Y.Offset + delta.Y)
				game:GetService('TweenService'):Create(frame, TweenInfo.new(dragSpeed), {Position = position}):Play()
			end

			frame.InputBegan:Connect(function(input)
				if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) then 
					dragToggle = true
					dragStart = input.Position
					startPos = frame.Position
					input.Changed:Connect(function()
						if input.UserInputState == Enum.UserInputState.End then
							dragToggle = false
						end
					end)
				end
			end)

			UIS.InputChanged:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
					if dragToggle then
						updateInput(input)
					end
				end
			end)	

			local istatus = false
			local GuiService = game:GetService("GuiService")
			local UserInputService = game:GetService("UserInputService")
			function getplatform()
				if (GuiService:IsTenFootInterface()) then
					return "Console"
				elseif (UserInputService.TouchEnabled and not UserInputService.MouseEnabled) then
					local DeviceSize = workspace.CurrentCamera.ViewportSize; 
					if ( DeviceSize.Y > 600 ) then
						return "Mobile (tablet)"
					else
						return "Mobile (phone)"
					end
				else
					return "Desktop"
				end
			end
			local platform = getplatform()

			screengui:FindFirstChildOfClass("Frame"):FindFirstChildOfClass("ImageButton")['MouseButton1Click']:Connect(function()
				pcall(function()
					setclipboard("https://discord.gg/Pk7VQqZvZr")
				end)
			end)
			if string.find(platform, "Mobile") then
				script['Parent']['Visible'] = true
				screengui:FindFirstChildOfClass("ImageButton")['MouseButton1Click']:Connect(function()
					istatus = not istatus
					script:FindFirstAncestorOfClass("ScreenGui"):findFirstChildOfClass("Frame")['Visible'] = not istatus
				end)
			end
			local list = {

			}

			local sucess, err = pcall(function()
				--элементы убирают у себя transparency
				for _, e in pairs(screengui:GetDescendants()) do
					--проверка
					if e:IsA("TextBox") or e:IsA("TextLabel") or e:IsA("TextButton") then
						table.insert(list,{e,e.BackgroundTransparency,e.TextTransparency})
						e.BackgroundTransparency = 1
						e.TextTransparency = 1
					elseif e:IsA("ImageLabel") or e:IsA("ImageButton") then
						table.insert(list,{e,e.BackgroundTransparency,e.ImageTransparency})
						e.BackgroundTransparency = 1
						e.ImageTransparency = 1
					elseif e:IsA("Frame") or e:IsA("ScrollingFrame") then
						table.insert(list,{e,e.BackgroundTransparency})
						e.BackgroundTransparency = 1
					else

					end
				end
			end)

			if not sucess then print(err) end

			local a,b = pcall(function()
				task.wait(2)
				--выставление аргументов
				local ts = game:GetService("TweenService")
				local info = TweenInfo.new(2.5)

				for _, t in pairs(list) do
					pcall(function()
						if t[1]:IsA("TextBox") or t[1]:IsA("TextLabel") or t[1]:IsA("TextButton") then
							ts:Create(t[1],info,{BackgroundTransparency = t[2]}):Play()
							ts:Create(t[1],info,{TextTransparency = t[3]}):Play()
							if t[3] == nil then
								ts:Create(t[1],info,{TextTransparency = 0})
							end
						elseif t[1]:IsA("ImageLabel") or t[1]:IsA("ImageButton") then
							ts:Create(t[1],info,{BackgroundTransparency = t[2]}):Play()
							ts:Create(t[1],info,{ImageTransparency = t[3]}):Play()
						elseif t[1]:IsA("ScrollingFrame") or t[1]:IsA("Frame") then
							ts:Create(t[1],info,{BackgroundTransparency = t[2]}):Play()       
						end
					end)
				end
			end)

			if not a then print(b) end
		end)
	end,
}

controller['Start'] = module['Start']

setmetatable(module, {
	__namecall = function(self, ...)
		local args = {...}
		warn("[SpineLibrary]: Hasn`t found function. Redirecting to controller. Arg1: "..args[1])
		return controller[args[1]][table.unpack(args, 2, #args)]
	end,
	__index = function(self, element)
		warn("[SpineLibrary]: Hasn`t found variable. Redirecting to controller.")
		return controller[element]
	end,
})
return module
