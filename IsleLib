function GetXY(GuiObject)
	local Max, May = GuiObject.AbsoluteSize.X, GuiObject.AbsoluteSize.Y
	local Px, Py = math.clamp(Mouse.X - GuiObject.AbsolutePosition.X, 0, Max), math.clamp(Mouse.Y - GuiObject.AbsolutePosition.Y, 0, May)
	return Px/Max, Py/May
end


function dropdown(dropdown_: ScrollingFrame, childs, callback)
	local example = dropdown_:FindFirstChild("Example")

	for _, child in childs do
		local TextButton: TextButton = example:Clone()
		TextButton['Name'] = "Xueta"
		TextButton['Parent'] = dropdown_
		TextButton['Visible'] = true

		if type(child) ~= "userdata" then
			TextButton:FindFirstChildOfClass("TextLabel").Text = child
		else
			if child:IsA("Model") or child:IsA("MeshPart") or child:IsA("UnionOperation") or child:IsA("Part") or child:IsA("BasePart") then
				TextButton:FindFirstChildOfClass("TextLabel").Text = child.Name
			elseif child:IsA("StringValue") or child:IsA("IntValue") or child:IsA("ObjectValue") then
				TextButton:FindFirstChildOfClass("TextLabel").Text = child.Value
			else
				pcall(function()
					TextButton:FindFirstChildOfClass("TextLabel").Text = child.Name
				end)
			end
		end

		TextButton:FindFirstChildOfClass("TextButton")['MouseButton1Click']:Connect(function()
			task.spawn(function()
				if callback then 
					callback(TextButton:FindFirstChildOfClass("TextLabel")['Text']:gsub("%<[^>]*>",""))
				else
					warn('[SpineLibrary]: Callback was not connected.')
				end
			end)
			for _, button in dropdown_:GetChildren() do
				if button:IsA("Frame") then
					ts:Create(button, TweenInfo.new(0.7), {BackgroundColor3 = Color3.new(0.243137, 0.243137, 0.243137)}):Play()
				end
			end
			ts:Create(TextButton, TweenInfo.new(0.7), {BackgroundColor3 = Color3.new(0.211765, 0.639216, 0.164706)}):Play()
		end)
	end
	dropdown_['CanvasSize'] = UDim2.new(0, 0, 0.295*#dropdown_:GetChildren(), 0)
end
function chipset(dropdown_: ScrollingFrame, childs, callback)
	local example = dropdown_:FindFirstChild("Example")
	local choosen = {}

	local BuildTable = {}
	for key, value in pairs(childs) do
		if typeof(value) == "table" then
			BuildTable[key] = value.Enabled or false
		else
			BuildTable[key] = value or false
		end
	end

	for key, child in childs do
		local TextButton: TextButton = example:Clone()
		TextButton['Name'] = "Xueta"
		TextButton['Parent'] = dropdown_
		TextButton['Visible'] = true

		if type(child) ~= "userdata" then
			TextButton:FindFirstChildOfClass("TextLabel").Text = key
		end

		TextButton:FindFirstChildOfClass("TextButton")['MouseButton1Click']:Connect(function()
			BuildTable[key] = not BuildTable[key]
			ts:Create(TextButton, TweenInfo.new(0.6), {BackgroundColor3 = BuildTable[key] and Color3.new(0, 0.705882, 0) or Color3.new(0.243137, 0.243137, 0.243137)}):Play()
			task.spawn(function()
				if callback then 
					callback(BuildTable)
				else
					warn('[SpineLibrary]: Callback was not connected.')
				end
			end)
		end)
	end
	dropdown_['CanvasSize'] = UDim2.new(0, 0, 0.295*#dropdown_:GetChildren(), 0)
end
